TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: restrict who can use the bot. Comma-separated Telegram chat IDs.
ALLOWED_CHAT_IDS=

# Alert date uses this timezone for /today and auto-alert scheduling.
TIMEZONE=Asia/Jakarta

# Auto-send daily alert to TELEGRAM_CHAT_ID and subscribed chats.
AUTO_ALERTS=false
DAILY_ALERT_TIME=20:00

# Check finished games and send recap. Requires saved pre-game predictions.
POST_GAME_ALERTS=true
POST_GAME_POLL_MINUTES=5

# Let the model save outcome memory and apply small future adjustments.
MODEL_MEMORY=true

# Telegram-first interaction. Terminal only logs unless PRINT_ALERT_TO_TERMINAL=true.
INTERACTIVE_AGENT=true
PRINT_ALERT_TO_TERMINAL=false

# Optional OpenAI summary. If disabled or key is empty, rule-based output is used.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4.1-mini
USE_OPENAI_SUMMARY=false

# Optional market and weather APIs for the Python knowledge/data layer.
ODDS_API_KEY=
THE_ODDS_API_KEY=
OPENWEATHER_API_KEY=

# Analyst Agent makes the final pre-game pick from stats, memory, H2H, and baseline model.
ANALYST_AGENT=true
ANALYST_AGENT_MODE=local
ANALYST_AGENT_TIMEOUT_MS=45000

# Optional external agent mode. Endpoint should accept JSON and return { "analyses": [...] }.
ANALYST_AGENT_URL=
ANALYST_AGENT_API_KEY=

# Keep this short so Telegram stays easy to read.
MAX_GAMES_PER_MESSAGE=8

# compact = context only, full = include advanced ISO/K/BB/K-BB/HR9 lines.
ALERT_DETAIL=compact

# Python executable for /predict Telegram command.
PYTHON_BIN=python
